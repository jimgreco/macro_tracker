PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/macro_tracker
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=true
# Optional: inline PEM cert or cert file path for DB TLS validation
PGSSL_CA_CERT=
PGSSL_CA_FILE=
SESSION_SECRET=change_this_session_secret
SESSION_TTL_DAYS=30
APP_BASE_URL=http://localhost:3000
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Local-only auth bypass for preview/dev testing (ignored in production)
LOCAL_AUTH_BYPASS=false
LOCAL_DEV_USER_ID=local-dev-user
LOCAL_DEV_USER_NAME=Local Preview User
LOCAL_DEV_USER_EMAIL=local-preview@example.com
# Apple Sign-In (required for Sign in with Apple)
APPLE_CLIENT_ID=com.macroflow.web
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
APPLE_REDIRECT_URI=http://localhost:3000/auth/apple/callback
APPLE_BUNDLE_ID=com.macroflow.app
# Stripe billing (required for paid subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
