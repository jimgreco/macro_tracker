{
  "name": "macro-tracker-app",
  "version": "1.0.0",
  "description": "Web macro tracker with natural language meal parsing",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "check": "node -e \"require('./src/db').initDb().then(() => console.log('DB initialized')).catch((err) => { console.error(err.message); process.exit(1); })\"",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "openai": "^4.86.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.18.0"
  }
}
